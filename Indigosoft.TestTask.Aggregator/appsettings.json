{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Aggregator": {
    "Exchanges": [
      {
        "Source": "ExchangeA",
        "WebSocketUrl": "ws://localhost:5100/ws/exchange-a",
        "InitialReconnectDelayMs": 1000,
        "MaxReconnectDelayMs": 30000,
        "IdleTimeoutSeconds": 10
      },
      {
        "Source": "ExchangeB",
        "WebSocketUrl": "ws://localhost:5100/ws/exchange-b",
        "InitialReconnectDelayMs": 1000,
        "MaxReconnectDelayMs": 30000,
        "IdleTimeoutSeconds": 10
      },
      {
        "Source": "ExchangeC",
        "WebSocketUrl": "ws://localhost:5100/ws/exchange-c",
        "InitialReconnectDelayMs": 1000,
        "MaxReconnectDelayMs": 30000,
        "IdleTimeoutSeconds": 10
      }
    ],
    "Channel": {
      "Capacity": 100000
    },
    "Deduplication": {
      "WindowSeconds": 60,
      "CleanupIntervalSeconds": 10
    }
  }
}
