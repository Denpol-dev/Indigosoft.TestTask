{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Aggregator": {
    "Channel": {
      "Capacity": 100000
    },
    "Deduplication": {
      "WindowSeconds": 60,
      "CleanupIntervalSeconds": 10
    }
  }
}
